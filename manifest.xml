      <bt:LongStrings>
        <!-- Supertips (Beschreibungstext im Tooltip) -->
        <bt:String id="Button.CornerRadius.Desc"     DefaultValue="Setzt den Eckenradius aller selektierten Shapes auf einen einheitlichen Wert (Eingabe in Pixeln)."/>
        <bt:String id="Button.ColorPicker.Desc"      DefaultValue="Wählt eine Farbe per Hex/RGB-Eingabe oder aus dem selektierten Shape und wendet sie auf Füllung, Linie oder Text an."/>
        <bt:String id="Button.FormatPainter.Desc"    DefaultValue="Überträgt ausgewählte Formatierungseigenschaften (Füllung, Linie, Schrift, Schatten) vom Quell-Shape auf selektierte Shapes."/>
        <bt:String id="Button.BrandCheck.Desc"       DefaultValue="Prüft alle Shapes und Texte auf Einhaltung der konfigurierten Brand-Richtlinien (Schriften, Farben, Schriftgrößen)."/>
        <bt:String id="Button.FindReplace.Desc"      DefaultValue="Sucht und ersetzt Text, Farben oder Schriftarten im gesamten Deck oder in ausgewählten Slides."/>
        <bt:String id="Button.RemoveComments.Desc"   DefaultValue="Entfernt alle Infront-Kommentar-Shapes aus dem gesamten Deck."/>
        <bt:String id="Button.RemoveRedBoxAll.Desc"  DefaultValue="Entfernt alle Red-Box-Shapes (INFRONT_REDBOX) aus allen Slides des Decks."/>
        <bt:String id="Button.GapH.Desc"             DefaultValue="Gleicht die horizontalen Abstände zwischen den selektierten Shapes an (Kantenabstände, nicht Mittelpunkte)."/>
        <bt:String id="Button.GapV.Desc"             DefaultValue="Gleicht die vertikalen Abstände zwischen den selektierten Shapes an (Kantenabstände, nicht Mittelpunkte)."/>
        <bt:String id="Button.GapOptions.Desc"       DefaultValue="Öffnet den Abstand-Equalizer mit erweiterten Optionen für präzise Abstandssteuerung."/>
        <bt:String id="Button.Agenda.Desc"           DefaultValue="Erstellt und verwaltet eine tag-basierte Agenda mit bis zu 8 Sektionen und automatischer Formatierung."/>
        <bt:String id="Button.MasterImport.Desc"     DefaultValue="Importiert Theme-Farben, Theme-Fonts oder Slide-Layouts aus einer anderen Präsentation."/>
        <bt:String id="Button.RedBox.Desc"           DefaultValue="Schaltet die Safe-Area-Begrenzungsbox (Red Box) auf der aktuellen Slide ein oder aus."/>
        <bt:String id="Button.RedBoxAllSlides.Desc"  DefaultValue="Fügt die Red Box auf allen Slides der Präsentation ein oder entfernt sie."/>
        <bt:String id="Button.RedBoxSettings.Desc"   DefaultValue="Konfiguriert Abstände, Farbe und Linienstärke der Red Box."/>
